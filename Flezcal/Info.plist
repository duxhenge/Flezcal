<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Flezcal needs your location to show flan and mezcal spots near you.</string>
	<key>BraveSearchAPIKey</key>
	<string>$(BRAVE_SEARCH_API_KEY)</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Flezcal uses your photo library to let you add photos of spots you visit.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Flezcal uses speech recognition so you can search by voice.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Flezcal needs microphone access for voice search.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
