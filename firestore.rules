rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Spots collection
    match /spots/{spotId} {
      // Anyone can read spots (even non-authenticated users can browse)
      allow read: if true;

      // Only authenticated users can create spots
      allow create: if request.auth != null
                    && request.resource.data.addedByUserID == request.auth.uid;

      // Only allow updates to specific safe fields
      allow update: if request.auth != null
                    && (
                      // Allow rating updates (from review submissions)
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['averageRating', 'reviewCount', 'categoryRatings']))
                      ||
                      // Allow offerings updates by any authenticated user
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['offerings', 'mezcalOfferings']))
                      ||
                      // Allow mezcal offering updates (legacy — kept for backward compat)
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['mezcalOfferings']))
                      ||
                      // Allow reporting (isReported, reportCount, reportedByUserIDs, isHidden)
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isReported', 'reportCount', 'reportedByUserIDs', 'isHidden']))
                      ||
                      // Allow community verification of imported spots:
                      // sets communityVerified=true and clears any accumulated flags.
                      // Only flips from false → true (can't un-verify from the client).
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['communityVerified', 'isReported', 'reportCount',
                                  'reportedByUserIDs', 'isHidden'])
                        && request.resource.data.communityVerified == true
                        && resource.data.communityVerified == false)
                      ||
                      // Allow adding/removing categories with per-user attribution + website detection tracking
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['categories', 'categoryAddedBy', 'websiteDetectedCategories']))
                      ||
                      // Allow verification tally updates (from verification votes)
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['verificationUpCount', 'verificationDownCount',
                                  'lastVerificationDate', 'verificationUserCount']))
                      ||
                      // Allow closure report count increment
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['closureReportCount']))
                      ||
                      // Admin-only: confirm closure or dismiss reports
                      (request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33"
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['locationStatus', 'closureReportCount']))
                      ||
                      // Owner-editable fields: only the verified owner can update these
                      (resource.data.ownerVerified == true
                        && resource.data.ownerUserId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['ownerBrands', 'ownerDetails', 'reservationURL', 'ownerLockedCategories']))
                      ||
                      // Allow analytics counter increments by any authenticated user
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['analyticsViewCount', 'analyticsReservationClicks']))
                      ||
                      // Allow geohash4 backfill by any authenticated user
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['geohash4']))
                    );

      // No deleting spots (admin only via Firebase console)
      allow delete: if false;

      // Analytics monthly rollup — any authenticated user can increment;
      // only the spot owner or admin can read.
      match /analytics_monthly/{monthId} {
        allow read: if request.auth != null
                    && (get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUserId == request.auth.uid
                        || request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33");
        allow create, update: if request.auth != null;
        allow delete: if false;
      }

      // Viewer log — users can write their own entry; only owner or admin can read.
      match /viewer_log/{userId} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUserId == request.auth.uid
                        || request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33");
        allow create, update: if request.auth != null
                              && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;

      // Only authenticated users can create reviews
      allow create: if request.auth != null
                    && request.resource.data.userID == request.auth.uid;

      // Allow reporting updates or category backfill
      allow update: if request.auth != null
                    && (
                      // Reporting fields
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isReported', 'reportCount', 'reportedByUserIDs', 'isHidden'])
                      ||
                      // Category backfill: set category only when it was previously null/unset
                      (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['category'])
                        && (!('category' in resource.data) || resource.data.category == null))
                    );

      // Only admin can delete reviews
      allow delete: if request.auth != null
                    && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }

    // Verifications collection — community verification votes
    match /verifications/{verificationId} {
      // Anyone can read verifications
      allow read: if true;

      // Only authenticated users can create, and must be their own vote
      allow create: if request.auth != null
                    && request.resource.data.userID == request.auth.uid;

      // Only the vote owner can update: vote, rating, updatedDate, isOriginalVerifier
      allow update: if request.auth != null
                    && resource.data.userID == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['vote', 'rating', 'updatedDate', 'isOriginalVerifier']);

      // Only the vote owner can retract (delete) their own verification
      allow delete: if request.auth != null
                    && resource.data.userID == request.auth.uid;
    }

    // Closure reports collection — community closure reports
    match /closure_reports/{reportId} {
      // Anyone can read closure reports
      allow read: if true;

      // Only authenticated users can create, and must be their own report
      allow create: if request.auth != null
                    && request.resource.data.reporterUserID == request.auth.uid;

      // Only admin can update (confirm or dismiss)
      allow update: if request.auth != null
                    && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";

      // No deleting closure reports
      allow delete: if false;
    }

    // User profiles — display names for leaderboard
    match /users/{userId} {
      // Anyone can read display names (needed for leaderboard)
      allow read: if true;

      // Users can only create/update their own document
      allow create, update: if request.auth != null
                            && request.auth.uid == userId;

      // Users can delete their own document (account deletion cleanup)
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Custom categories collection — user-created food categories
    match /customCategories/{categoryId} {
      // Anyone can read custom categories
      allow read: if true;

      // Only authenticated users can create custom categories
      allow create: if request.auth != null;

      // Only allow pickCount increment updates (authenticated users)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['pickCount']);

      // No deleting custom categories (admin only)
      allow delete: if false;

      // Pickers subcollection — deduplicates pickCount per user
      match /pickers/{userId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
                              && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    // Custom search events — trend tracking for custom categories
    match /customSearchEvents/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Admin collections — only accessible by the app owner
    match /admin_revenue/{document} {
      allow read, write: if request.auth != null && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }
    match /admin_costs/{document} {
      allow read, write: if request.auth != null && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }
    match /admin_reminders/{document} {
      allow read, write: if request.auth != null && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }
    match /admin_notes/{document} {
      allow read, write: if request.auth != null && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }

    // Regional analytics averages — readable by any authenticated user,
    // writable only by admin (or Cloud Functions via admin SDK).
    match /analytics_regions/{geohash} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == "FFrKO5dcaNNlTzM6msCXcLha1d33";
    }
  }
}
